# .env.example
# 이 파일을 .env로 복사한 후 값을 채워 사용하세요.
# cp .env.example .env

# ──────────────────────────────────────────────
# 공통
# ──────────────────────────────────────────────
LOG_DIR=data/logs

# ──────────────────────────────────────────────
# 국가법령정보 API (법령 / 판례 / 해석례 공통)
# ──────────────────────────────────────────────
LAW_LIST_URL=https://www.law.go.kr/DRF/lawSearch.do
LAW_DETAIL_URL=https://www.law.go.kr/DRF/lawService.do

# ──────────────────────────────────────────────
# 데이터 저장 경로
# ──────────────────────────────────────────────
LAW_RAW_DIR=data/raw/laws
PREC_RAW_DIR=data/raw/precedents
EXPC_RAW_DIR=data/raw/interpretations
CONTRACT_RAW_DIR=data/raw/contracts
FTC_SEED_DIR=data/seed
